@startuml

' ==========================================
' ENTIDADES INDEPENDIENTES
' ==========================================

entity "Ciudades" as Ciudades {
    * codigo: INT <<PK>>
    --
    * nombre: VARCHAR(100)
    * codigo_postal: VARCHAR(20)
}

entity "Generos" as Generos {
    * codigo: INT <<PK>>
    --
    * nombre: VARCHAR(50)
}

entity "Directores" as Directores {
    * codigo: INT <<PK>>
    --
    * nombres: VARCHAR(50)
    * apellidos: VARCHAR(50)
    * fecha_nacimiento: DATE
    * sexo: CHAR(1)
}

entity "Actores" as Actores {
    * codigo: INT <<PK>>
    --
    * nombres: VARCHAR(50)
    * apellidos: VARCHAR(50)
    * fecha_nacimiento: DATE
    * sexo: CHAR(1)
}

' ==========================================
' ENTIDADES DEPENDIENTES
' ==========================================

entity "Sucursales" as Sucursales {
    * codigo: INT <<PK>>
    --
    * nombre: VARCHAR(100)
    * direccion: VARCHAR(200)
    * telefono: VARCHAR(15)
    * correo: VARCHAR(50)
    * codigo_ciudad: INT <<FK>>
}

entity "Clientes" as Clientes {
    * codigo: INT <<PK>>
    --
    * nombres: VARCHAR(50)
    * apellidos: VARCHAR(50)
    * telefono: VARCHAR(15)
    * fecha_nacimiento: DATE
    * cantidad_entradas: INT
    * sexo: CHAR(1)
    * correo: VARCHAR(50)
    * ciudad_residencia: INT <<FK>>
}

entity "Peliculas" as Peliculas {
    * codigo: INT <<PK>>
    --
    * nombre: VARCHAR(100)
    * codigo_director: INT <<FK>>
    * duracion_minutos: INT
    * clasificacion: VARCHAR(10)
    * fecha_nacimiento: DATE
    * portada: BLOB
}

entity "Generos_Peliculas" as Generos_Peliculas {
    * codigo_pelicula: INT <<FK>>
    * codigo_generos: INT <<FK>>
}

entity "Actores_Peliculas" as Actores_Peliculas {
    * codigo_pelicula: INT <<FK>>
    * codigo_actor: INT <<FK>>
}

entity "Salas" as Salas {
    * codigo: INT <<PK>>
    --
    * nombre: VARCHAR(50)
    * capacidad: INT
    * codigo_sucursal: INT <<FK>>
}

entity "Empleados" as Empleados {
    * codigo: INT <<PK>>
    --
    * nombres: VARCHAR(50)
    * apellidos: VARCHAR(50)
    * sexo: CHAR(1)
    * telefono: VARCHAR(15)
    * correo: VARCHAR(50)
    * puesto: VARCHAR(20)
    * codigo_sucursal: INT <<FK>>
}

entity "Asientos" as Asientos {
    * codigo: INT <<PK>>
    --
    * numero: INT
    * fila: VARCHAR(5)
    * codigo_sala: INT <<FK>>
}

entity "Funciones" as Funciones {
    * codigo: INT <<PK>>
    --
    * fecha: DATE
    * hora_inicio: TIME
    * hora_fin: TIME
    * precio_entrada: DECIMAL(10,2)
    * codigo_pelicula: INT <<FK>>
    * codigo_sala: INT <<FK>>
}

entity "Ventas" as Ventas {
    * codigo: INT <<PK>>
    --
    * fecha: DATE
    * hora: TIME
    * precio_total: DECIMAL(10,2)
    * codigo_cliente: INT <<FK>>
    * codigo_empleado: INT <<FK>>
    * codigo_sucursal: INT <<FK>>
}

entity "Boletos" as Boletos {
    * codigo: INT <<PK>>
    --
    * precio_aplicado: DECIMAL(10,2)
    * codigo_venta: INT <<FK>>
    * codigo_funcion: INT <<FK>>
    * codigo_asiento: INT <<FK>>
}

' ==========================================
' RELACIONES (CARDINALIDADES)
' ==========================================

' Relaciones de Ciudades
Ciudades ||--o{ Sucursales : "tiene"
Ciudades ||--o{ Clientes : "reside en"

' Relaciones de Películas (Directores, Géneros, Actores)
Directores ||--o{ Peliculas : "dirige"
Generos ||--o{ Generos_Peliculas : "tiene"
Peliculas ||--o{ Generos_Peliculas : "pertenece a"
Actores ||--o{ Actores_Peliculas : "actúa en"
Peliculas ||--o{ Actores_Peliculas : "tiene elenco"

' Relaciones de Sucursales
Sucursales ||--o{ Salas : "posee"
Sucursales ||--o{ Empleados : "contrata"
Sucursales ||--o{ Ventas : "registra"

' Relaciones de Salas y Asientos
Salas ||--o{ Asientos : "contiene"
Salas ||--o{ Funciones : "alberga"

' Relaciones de Funciones
Peliculas ||--o{ Funciones : "se proyecta en"

' Relaciones de Ventas
Clientes ||--o{ Ventas : "realiza"
Empleados ||--o{ Ventas : "procesa"

' Relaciones de Boletos (Detalle de Venta)
Ventas ||--|{ Boletos : "desglosa"
Funciones ||--o{ Boletos : "emite"
Asientos ||--o{ Boletos : "se asigna a"

@enduml